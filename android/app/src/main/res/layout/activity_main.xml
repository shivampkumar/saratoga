<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030712"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SARATOGA"
                android:textColor="#F9FAFB"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:id="@+id/statusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_ready"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="boot"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="on-device clinical co-pilot · offline-first · airplane-mode"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="3dp"
            android:paddingBottom="14dp" />

        <!-- CTA ROW -->
        <Button
            android:id="@+id/btnLoad"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="LOAD MODELS"
            android:textColor="#F9FAFB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_primary"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="56dp"
                android:text="● RECORD"
                android:textColor="#F9FAFB"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_danger"
                android:fontFamily="monospace"
                android:enabled="false" />

            <Button
                android:id="@+id/btnSync"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="SYNC 0"
                android:textColor="#F9FAFB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_primary"
                android:fontFamily="monospace"
                android:layout_marginStart="6dp"
                android:enabled="false" />
        </LinearLayout>

        <!-- STATUS LINE -->
        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="waiting on model load..."
            android:textColor="#9CA3AF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="8dp"
            android:paddingBottom="10dp" />

        <!-- TRANSCRIPT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:padding="10dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@drawable/accent_amber"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TRANSCRIPT"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/transcript"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:paddingTop="4dp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>
        </LinearLayout>

        <!-- DDX CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:padding="10dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@drawable/accent_blue"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="τ1  DIFFERENTIAL · MUST-RULE-OUTS"
                        android:textColor="#3B82F6"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tau1Meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tau1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#DBEAFE"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- RED FLAG CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:padding="10dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@drawable/accent_red"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="τ3  RED FLAG"
                        android:textColor="#EF4444"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tau3Meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tau3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FCA5A5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- MED REC CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:padding="10dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@drawable/accent_green"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="τ4  MEDICATION REC"
                        android:textColor="#10B981"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tau4Meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#6B7280"
                        android:textSize="9sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tau4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#A7F3D0"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- FHIR CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="@drawable/accent_amber"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="FHIR QUEUE · offline-buffered"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/fhirBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 queued"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <TextView
                android:id="@+id/fhir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:paddingTop="6dp"
                android:text="(no encounters yet)" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
