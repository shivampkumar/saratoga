<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SARATOGA"
            android:textColor="#FBBF24"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="on-device clinical co-pilot • offline / airplane-mode"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btnLoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load models" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Record"
                android:enabled="false" />

            <Button
                android:id="@+id/btnSync"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Sync FHIR (0)"
                android:enabled="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="waiting..."
            android:textColor="#E5E7EB"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TRANSCRIPT"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:paddingTop="12dp" />
        <TextView
            android:id="@+id/transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F9FAFB"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:paddingTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DIFFERENTIAL + MUST-RULE-OUTS (τ1)"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:paddingTop="16dp" />
        <TextView
            android:id="@+id/tau1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#60A5FA"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RED FLAG (τ3)"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:paddingTop="16dp" />
        <TextView
            android:id="@+id/tau3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F87171"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MEDICATION REC (τ4)"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:paddingTop="16dp" />
        <TextView
            android:id="@+id/tau4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#34D399"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FHIR QUEUE (offline-buffered)"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:paddingTop="16dp" />
        <TextView
            android:id="@+id/fhir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:paddingTop="4dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
